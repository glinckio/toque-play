# ============================================================
# EXAMPLE ONLY — copy to .env and fill with REAL secrets.
# NEVER commit .env. Real secrets must be unique per environment.
# ============================================================

# Database
DATABASE_URL="postgresql://USER:PASS@HOST:5432/toqueplay?schema=public"

# JWT — use long random strings (≥ 64 chars). ACCESS and REFRESH MUST differ.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64BYTE_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_64BYTE_HEX
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated origins (REQUIRED in production)
CORS_ORIGINS=http://localhost:3001,http://localhost:19006,exp://localhost:19000

# Google OAuth
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID

# Email (Resend)
RESEND_API_KEY=re_REPLACE_WITH_RESEND_KEY
MAIL_FROM=no-reply@yourdomain.com

# App
PORT=3000
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_STRIPE_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=REPLACE_WITH_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=REPLACE_WITH_MINIO_SECRET_KEY
MINIO_BUCKET=toqueplay
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# Sentry (optional)
SENTRY_DSN=

# Firebase (push notifications, optional)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# LGPD — current Terms/Privacy version. Bump to force re-consent.
TERMS_VERSION=v1
