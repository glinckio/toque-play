# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/toqueplay?schema=public"

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
MAIL_FROM=onboarding@resend.dev

# App
PORT=3000
NODE_ENV=development

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=toqueplayadmin
MINIO_SECRET_KEY=toqueplaysecret
MINIO_BUCKET=toqueplay
MINIO_USE_SSL=false
